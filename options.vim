" Setting line number
set number
set relativenumber

" Setting indent to 4 spaces
set expandtab
set shiftwidth=4
set softtabstop=4
set tabstop=4
set smartindent

" Setting syntax highlighting
syntax on
syntax enable

" Setting search highlighting
set hlsearch
set incsearch

" Setting nocompatible mode
set nocompatible

" netrw stuff
filetype plugin on
